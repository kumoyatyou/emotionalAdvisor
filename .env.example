# ==========================================
# 🧠 核心大模型配置 (Core LLM Configuration)
# ==========================================
# API 密钥 (支持 OpenAI、硅基流动、DeepSeek、本地模型等)
OPENAI_API_KEY=your_api_key_here
# API 代理/基础地址 (默认: https://api.openai.com/v1)
OPENAI_API_BASE=https://api.openai.com/v1
# 全局默认模型名称 (如 gpt-4o, deepseek-chat, Pro/moonshotai/Kimi-K2.5 等)
MODEL_NAME=gpt-4o
# 模型温度/创造力设置 (0.0 - 1.0，值越小越严谨，越大越发散)
TEMPERATURE=0.7

# ==========================================
# 🎯 专有技能模型配置 (Skill-specific Models - 可选)
# 如果以下配置留空，系统将默认使用上方的全局 MODEL_NAME
# ==========================================
# 追爱军师 (SimpSkill) 专用模型 (如需不同模型分析情感，可单独配置)
SIMP_MODEL=
# 角色模拟 (NuwaSkill) 专用模型 (建议使用逻辑更强的模型)
NUWA_MODEL=
# 八字算命 (BaziSkill) 专用模型 (如需独立模型进行推演，可单独配置)
BAZI_MODEL=

# ==========================================
# 📚 知识库与本地存储配置 (RAG & Storage)
# ==========================================
# 知识库使用的向量模型 (如 text-embedding-3-small, Qwen/Qwen3-Embedding-8B 等)
EMBEDDING_MODEL=text-embedding-3-small
# Chroma 向量数据库本地持久化存储路径
DB_PERSIST_PATH=./db

# ==========================================
# 🔄 微信实时同步配置 (WeFlow Sync - 可选)
# 如果不需要实时同步，或希望使用手动导入数据，可将 URL 前面加 # 注释掉
# ==========================================
# 本地 WeFlow 监听地址 (默认: http://127.0.0.1:5031/api/v1/push/messages)
WECHAT_SYNC_URL=http://127.0.0.1:5031/api/v1/push/messages
# WeFlow 的 API Token (必须填写，否则会报 401 错误；请在 WeFlow 设置中获取)
WECHAT_SYNC_TOKEN=your_weflow_token_here
