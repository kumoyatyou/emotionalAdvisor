# ==========================================
# AI Model Configuration (OpenAI Compatible)
# ==========================================
# The API key for your LLM provider (e.g., OpenAI, DeepSeek, Anthropic, etc.)
OPENAI_API_KEY=sk-xxxxxx
# The base URL of the LLM API endpoint (default: https://api.openai.com/v1)
OPENAI_API_BASE=https://api.openai.com/v1
# The model name to be used (e.g., gpt-4o, deepseek-chat, claude-3-5-sonnet-20240620)
MODEL_NAME=gpt-4o
# ==========================================
# WeChat Realtime Sync Configuration (WeFlow)
# ==========================================
# The local SSE URL provided by WeFlow HTTP API
WECHAT_SYNC_URL=http://127.0.0.1:5031/api/v1/push/messages
# The Access Token for WeFlow HTTP API (Required if authentication is enabled in WeFlow)
WECHAT_SYNC_TOKEN=your_weflow_token_here
